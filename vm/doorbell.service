[Unit]
Description=Doorbell HomeKit Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/doorbell
ExecStart=/usr/bin/node /opt/doorbell/doorbell.js
Restart=always
RestartSec=10
StandardOutput=append:/var/log/doorbell.log
StandardError=append:/var/log/doorbell.log

[Install]
WantedBy=multi-user.target
