# Eufy secondary account credentials
EUFY_USERNAME=secondary-eufy-email@example.com
EUFY_PASSWORD=secondary-eufy-password
EUFY_COUNTRY=US

# E340 doorbell serial number (found in Eufy app or logs)
DEVICE_SERIAL=T8214XXXXXXXXXXX

# HomeKit pairing code (format: XXX-XX-XXX)
HOMEKIT_PIN=123-45-678

# HomeKit MAC address (unique per accessory, format: XX:XX:XX:XX:XX:XX)
HOMEKIT_USERNAME=AA:BB:CC:DD:EE:FF

# HomeKit HAP server port
HOMEKIT_PORT=47128

# Optional: password to protect the web dashboard (HTTP Basic Auth)
DASHBOARD_PASSWORD=
